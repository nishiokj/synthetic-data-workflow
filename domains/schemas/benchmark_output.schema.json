{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_artifact",
    "judge_artifact",
    "ability_z",
    "environment_y"
  ],
  "properties": {
    "agent_artifact": {
      "type": "object",
      "required": ["benchmark_case"],
      "additionalProperties": false,
      "properties": {
        "benchmark_case": {"$ref": "#/$defs/benchmark_case"},
        "environment_artifact": {"$ref": "#/$defs/environment_artifact"}
      }
    },
    "judge_artifact": {
      "type": "object",
      "required": [
        "score_x",
        "proxy_claim",
        "diagnostic_pressure",
        "scoring_contract",
        "leakage_risks",
        "known_limits",
        "coverage_tags",
        "negative_controls"
      ],
      "additionalProperties": false,
      "properties": {
        "score_x": {"$ref": "#/$defs/score_x"},
        "proxy_claim": {"type": "string", "minLength": 80},
        "diagnostic_pressure": {
          "type": "array",
          "minItems": 2,
          "items": {"type": "string"}
        },
        "scoring_contract": {"$ref": "#/$defs/scoring_contract"},
        "leakage_risks": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "known_limits": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "coverage_tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "negative_controls": {"$ref": "#/$defs/negative_controls"}
      }
    },
    "ability_z": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "sub_abilities": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "environment_y": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "assumptions": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "benchmark_case": {
      "type": "object",
      "required": ["prompt"],
      "additionalProperties": true,
      "properties": {
        "prompt": {"type": "string", "minLength": 20},
        "setup": {"type": "string"},
        "inputs": {"type": "object"},
        "environment": {"type": "object"}
      }
    },
    "environment_artifact": {
      "type": "object",
      "required": ["kind", "payload"],
      "additionalProperties": false,
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "payload": {"type": "object"}
      }
    },
    "score_x": {
      "type": "object",
      "required": ["score_type", "dimensions"],
      "additionalProperties": true,
      "properties": {
        "score_type": {"type": "string"},
        "range": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {"type": "number"}
        },
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "weight", "high_score_criterion", "low_score_criterion"],
            "additionalProperties": true,
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "weight": {"type": "number", "minimum": 0, "maximum": 1},
              "high_score_criterion": {"type": "string", "minLength": 20},
              "low_score_criterion": {"type": "string", "minLength": 20}
            }
          }
        }
      }
    },
    "scoring_contract": {
      "type": "object",
      "required": ["credit", "penalties"],
      "additionalProperties": true,
      "properties": {
        "credit": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "penalties": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "uncertainty_policy": {"type": "string"}
      }
    },
    "negative_controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["output", "should_fail_because"],
        "additionalProperties": true,
        "properties": {
          "output": {"type": "string", "minLength": 1},
          "should_fail_because": {"type": "string", "minLength": 10}
        }
      }
    }
  }
}
